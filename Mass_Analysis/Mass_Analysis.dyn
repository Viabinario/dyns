    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# Nodo de diagnóstico — conecta su OUT a un Watch\r\nimport clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nall_rooms = []\r\n\r\nhost_rooms = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_Rooms)\\\r\n    .WhereElementIsNotElementType()\\\r\n    .ToElements()\r\nfor r in host_rooms:\r\n    if r.Area > 0:\r\n        all_rooms.append((r, doc))\r\n\r\nlink_instances = FilteredElementCollector(doc)\\\r\n    .OfClass(RevitLinkInstance)\\\r\n    .ToElements()\r\nfor li in link_instances:\r\n    link_doc = li.GetLinkDocument()\r\n    if link_doc is None:\r\n        continue\r\n    for r in FilteredElementCollector(link_doc)\\\r\n            .OfCategory(BuiltInCategory.OST_Rooms)\\\r\n            .WhereElementIsNotElementType()\\\r\n            .ToElements():\r\n        if r.Area > 0:\r\n            all_rooms.append((r, link_doc))\r\n\r\n# Imprime todos los parámetros disponibles del primer room\r\ndiagnostico = []\r\nif all_rooms:\r\n    room, _ = all_rooms[0]\r\n    for p in room.Parameters:\r\n        try:\r\n            val = p.AsString() or p.AsValueString() or str(p.AsDouble())\r\n        except:\r\n            val = \"(error)\"\r\n        diagnostico.append(\"{} = {}\".format(p.Definition.Name, val))\r\n\r\nOUT = diagnostico",
