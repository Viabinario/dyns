      "Description": "Runs an embedded Python script."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nWORKSET_NAME = \"Rooms_3D_Visual\"\r\nworkset_id = None\r\nfor ws in FilteredWorksetCollector(doc).OfKind(WorksetKind.UserWorkset):\r\n    if ws.Name == WORKSET_NAME:\r\n        workset_id = ws.Id\r\n        break\r\n\r\nmasses = [\r\n    m for m in FilteredElementCollector(doc)\r\n        .OfCategory(BuiltInCategory.OST_Mass)\r\n        .WhereElementIsNotElementType()\r\n        .ToElements()\r\n    if m.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM) is not None\r\n    and m.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM)\r\n        .AsInteger() == workset_id.IntegerValue\r\n]\r\n\r\n# Extraer valores únicos de Room_Level y VivPlanta\r\nlevels   = set()\r\nplantas  = set()\r\ntipos    = set()\r\n\r\nfor mass in masses:\r\n    p = mass.get_Parameter(BuiltInParameter.ALL_MODEL_INSTANCE_COMMENTS)\r\n    if p is None:\r\n        continue\r\n    comments = p.AsString() or \"\"\r\n    for part in comments.split(\" | \"):\r\n        if part.startswith(\"Room_Level:\"):\r\n            levels.add(part.split(\":\",1)[1].strip())\r\n        elif part.startswith(\"VivPlanta:\"):\r\n            plantas.add(part.split(\":\",1)[1].strip())\r\n        elif part.startswith(\"VivTipo:\"):\r\n            tipos.add(part.split(\":\",1)[1].strip())\r\n\r\nOUT = [\r\n    \"Room_Level únicos: {}\".format(sorted(levels)),\r\n    \"VivPlanta únicos: {}\".format(sorted(plantas)),\r\n    \"VivTipo únicos: {}\".format(sorted(tipos)),\r\n]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "34599fd033e44082a54af9b3c3b38ddf",
