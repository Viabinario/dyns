    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# ══════════════════════════════════════════════════════════════\r\n# REGLAS DE COLOR\r\n# Formato: (\"label del PARAM_MAP\", \"modo\", \"valor\", (R, G, B))\r\n# Modos: \"equals\" | \"contains\" | \"startswith\" | \"endswith\"\r\n# Comparación ignora mayúsculas/minúsculas\r\n# ══════════════════════════════════════════════════════════════\r\nCOLOR_RULES = [\r\n    # Por Tipo de Recinto\r\n    # (\"Room_Name\", \"contains\", \"SALÓN\", (80, 180, 255)),   # azul\r\n    # (\"Room_Name\", \"contains\", \"DORMITORIO 2\", (255, 180,  80)),   # naranja\r\n    # (\"Room_Name\", \"contains\", \"DORMITORIO 3\", (120, 220, 120)),   # verde\r\n      (\"Room_Name\", \"contains\", \"Büro\", (255, 100, 100)),   # rojo\r\n      (\"Room_Name\", \"contains\", \"Bad\", (120, 220, 120)),\r\n      (\"Room_Name\", \"contains\", \"Balkon\", (80, 180, 255)),\r\n    \r\n    # Por bloque — usando \"contains\" porque el nivel incluye prefijo numérico\r\n    # (\"Room_Level\", \"contains\", \"BL01\", (255, 100, 100)),   # rojo\r\n    # (\"Room_Level\", \"contains\", \"BL2\", (255, 180,  80)),   # naranja\r\n    # (\"Room_Level\", \"contains\", \"BL03\", ( 80, 180, 255)),   # azul\r\n    # (\"Room_Level\", \"contains\", \"BL04\", (120, 220, 120)),   # verde\r\n\r\n    # Zonas especiales\r\n    # (\"Room_Level\", \"contains\", \"GARAJE\",    (160, 160, 160)),  # gris\r\n    # (\"Room_Level\", \"contains\", \"DEPURADORA\",(100, 200, 200)),  # cyan\r\n    # (\"Room_Level\", \"contains\", \"PISCINA\",   ( 80, 140, 255)),  # azul agua\r\n    # (\"Room_Level\", \"contains\", \"LÁMINA\",    ( 80, 140, 255)),  # azul agua\r\n\r\n    # Por planta si lo necesitas\r\n    # (\"VivPlanta\", \"equals\", \"P00\", (200, 255, 200)),\r\n    # (\"VivPlanta\", \"equals\", \"S01\", (200, 200, 255)),\r\n\r\n    # Por tipo de vivienda\r\n    # (\"VivTipo\", \"equals\", \"TR\", (220, 200, 100)),\r\n]\r\nDEFAULT_COLOR = (220, 220, 220)  # gris para rooms sin regla — None para no aplicar\r\nTRANSPARENCY  = 30               # 0 = opaco, 100 = invisible\r\n# ══════════════════════════════════════════════════════════════\r\n\r\n# ── Vista 3D activa ────────────────────────────────────────\r\nactive_view = doc.ActiveView\r\nif not isinstance(active_view, View3D):\r\n    OUT = [\"ERROR: la vista activa no es una vista 3D.\"]\r\n    raise Exception(\"Vista activa no es 3D\")\r\n\r\n# ── Recoger masas del workset Rooms_3D_Visual ──────────────\r\nWORKSET_NAME = \"Rooms_3D_Visual\"\r\nworkset_id = None\r\nfor ws in FilteredWorksetCollector(doc).OfKind(WorksetKind.UserWorkset):\r\n    if ws.Name == WORKSET_NAME:\r\n        workset_id = ws.Id\r\n        break\r\n\r\nif workset_id is None:\r\n    OUT = [\"ERROR: workset '{}' no encontrado.\".format(WORKSET_NAME)]\r\n    raise Exception(\"Workset no encontrado\")\r\n\r\nmasses = [\r\n    m for m in FilteredElementCollector(doc)\r\n        .OfCategory(BuiltInCategory.OST_Mass)\r\n        .WhereElementIsNotElementType()\r\n        .ToElements()\r\n    if m.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM) is not None\r\n    and m.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM)\r\n        .AsInteger() == workset_id.IntegerValue\r\n]\r\n\r\n# ── Leer valor de Comments por label ──────────────────────\r\ndef get_comment_value(mass, label):\r\n    p = mass.get_Parameter(BuiltInParameter.ALL_MODEL_INSTANCE_COMMENTS)\r\n    if p is None:\r\n        return None\r\n    for part in (p.AsString() or \"\").split(\" | \"):\r\n        if part.startswith(label + \":\"):\r\n            val = part.split(\":\", 1)[1].strip()\r\n            return val if val and val != \"0.0\" else None\r\n    return None\r\n\r\n# ── Evaluar modo de comparación ────────────────────────────\r\ndef rule_matches(comment_val, mode, rule_value):\r\n    a = comment_val.lower()\r\n    b = rule_value.lower()\r\n    if mode == \"equals\":\r\n        return a == b\r\n    elif mode == \"contains\":\r\n        return b in a\r\n    elif mode == \"startswith\":\r\n        return a.startswith(b)\r\n    elif mode == \"endswith\":\r\n        return a.endswith(b)\r\n    return False\r\n\r\n# ── Buscar patrón sólido una sola vez ─────────────────────\r\nsolid_pattern_id = None\r\nfor fp in FilteredElementCollector(doc).OfClass(FillPatternElement):\r\n    if fp.GetFillPattern().IsSolidFill:\r\n        solid_pattern_id = fp.Id\r\n        break\r\n\r\n# ── Crear OverrideGraphicSettings ─────────────────────────\r\ndef make_override(r, g, b):\r\n    ogs = OverrideGraphicSettings()\r\n    color = Color(r, g, b)\r\n    ogs.SetSurfaceForegroundPatternColor(color)\r\n    ogs.SetSurfaceForegroundPatternVisible(True)\r\n    if solid_pattern_id:\r\n        ogs.SetSurfaceForegroundPatternId(solid_pattern_id)\r\n    ogs.SetSurfaceTransparency(TRANSPARENCY)\r\n    ogs.SetProjectionLineColor(color)\r\n    return ogs\r\n\r\n# ── Aplicar overrides ──────────────────────────────────────\r\ncolored   = 0\r\ndefaulted = 0\r\nno_match_names = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor mass in masses:\r\n    matched_color = None\r\n\r\n    for label, mode, value, rgb in COLOR_RULES:\r\n        comment_val = get_comment_value(mass, label)\r\n        if comment_val and rule_matches(comment_val, mode, value):\r\n            matched_color = rgb\r\n            break\r\n\r\n    if matched_color:\r\n        active_view.SetElementOverrides(mass.Id, make_override(*matched_color))\r\n        colored += 1\r\n    elif DEFAULT_COLOR:\r\n        active_view.SetElementOverrides(mass.Id, make_override(*DEFAULT_COLOR))\r\n        defaulted += 1\r\n        no_match_names.append(mass.Name)\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = [\r\n    \"✓ {} masas coloreadas por regla\".format(colored),\r\n    \"○ {} masas con color por defecto\".format(defaulted),\r\n    \"Sin regla: {}\".format(no_match_names[:20]) if no_match_names else \"Todas con regla\"\r\n]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "28799cbe95c944b2878571066acca8f6",
