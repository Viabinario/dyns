    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nWORKSET_NAME = \"Rooms_3D_Visual\"\r\n\r\n# ══════════════════════════════════════════════════════════════\r\n# PARAM_MAP — nombres confirmados por el nodo de diagnóstico\r\n# ══════════════════════════════════════════════════════════════\r\nPARAM_MAP = [\r\n    # Parámetros nativos leídos por nombre — más fiable en vinculados\r\n    (\"Room_Name\",       \"Name\"),\r\n    (\"Room_Number\",     \"Number\"),\r\n    (\"Room_Level\",      \"Level\"),\r\n    (\"Room_Department\", \"Department\"),\r\n    (\"Room_Area_m2\",    \"Area\"),          # se convierte a m² aparte\r\n    # Parámetros de proyecto\r\n    (\"VivNumero\",       \"DAT_TXT_VivNumero\"),\r\n    (\"VivPlanta\",       \"DAT_TXT_VivPlanta\"),\r\n    (\"VivTipo\",         \"DAT_TXT_VivTipo\"),\r\n    (\"Bloque\",          \"DAT_TXT_VivBloque\"),\r\n    (\"Categoria\",       \"AHM_CNT_00_Categoria\"),\r\n    (\"AcabadoSuelo\",    \"AHM_MAT_AcabadodelSuelo\"),\r\n    (\"AcabadoMuro\",     \"AHM_MAT_AcabadodelMuro\"),\r\n]\r\n# ══════════════════════════════════════════════════════════════\r\n\r\n# ── 1. Workset ─────────────────────────────────────────────\r\nworkset_id = None\r\nfor ws in FilteredWorksetCollector(doc).OfKind(WorksetKind.UserWorkset):\r\n    if ws.Name == WORKSET_NAME:\r\n        workset_id = ws.Id\r\n        break\r\n\r\nif workset_id is None:\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n    new_ws = Workset.Create(doc, WORKSET_NAME)\r\n    workset_id = new_ws.Id\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n\r\n# ── 2. Recoger rooms ───────────────────────────────────────\r\nall_rooms = []\r\n\r\nfor r in FilteredElementCollector(doc)\\\r\n        .OfCategory(BuiltInCategory.OST_Rooms)\\\r\n        .WhereElementIsNotElementType().ToElements():\r\n    if r.Area > 0:\r\n        all_rooms.append((r, doc, None))\r\n\r\nfor li in FilteredElementCollector(doc)\\\r\n        .OfClass(RevitLinkInstance).ToElements():\r\n    link_doc = li.GetLinkDocument()\r\n    if link_doc is None:\r\n        continue\r\n    transform = li.GetTotalTransform()\r\n    for r in FilteredElementCollector(link_doc)\\\r\n            .OfCategory(BuiltInCategory.OST_Rooms)\\\r\n            .WhereElementIsNotElementType().ToElements():\r\n        if r.Area > 0:\r\n            all_rooms.append((r, link_doc, transform))\r\n\r\n# ── 3. Helpers ─────────────────────────────────────────────\r\ndef is_valid_solid(geo):\r\n    try:\r\n        if geo is None or not isinstance(geo, Solid):\r\n            return False\r\n        if geo.Volume <= 1e-6 or geo.Faces.Size == 0:\r\n            return False\r\n        return True\r\n    except:\r\n        return False\r\n\r\ndef get_room_value(room, param_def):\r\n    try:\r\n        p = room.LookupParameter(param_def)\r\n\r\n        if p is None:\r\n            return \"\"\r\n\r\n        # Área: convertir de ft² a m²\r\n        if param_def == \"Area\":\r\n            raw = p.AsDouble()\r\n            if raw > 0:\r\n                return \"{:.2f}\".format(raw * 0.092903)\r\n            return \"\"\r\n\r\n        # Intentar AsString primero\r\n        val = p.AsString()\r\n        if val and val.strip() and val != \"0.0\":\r\n            return val.strip()\r\n\r\n        # Si no, AsValueString (para parámetros numéricos o de tipo)\r\n        val = p.AsValueString()\r\n        if val and val.strip() and val != \"0.0\":\r\n            return val.strip()\r\n\r\n        return \"\"\r\n    except:\r\n        return \"\"\r\n\r\n# ── 4. Crear masas ─────────────────────────────────────────\r\ncat_id  = ElementId(BuiltInCategory.OST_Mass)\r\ncreated = []\r\nerrors  = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nfor room, source_doc, transform in all_rooms:\r\n    room_name = room.get_Parameter(BuiltInParameter.ROOM_NAME).AsString() or \"?\"\r\n    try:\r\n        calc   = SpatialElementGeometryCalculator(source_doc)\r\n        result = calc.CalculateSpatialElementGeometry(room)\r\n        geo    = result.GetGeometry()\r\n\r\n        if transform is not None and not transform.IsIdentity:\r\n            geo = SolidUtils.CreateTransformed(geo, transform)\r\n\r\n        if not is_valid_solid(geo):\r\n            errors.append(\"{}: geometría no válida, omitida\".format(room_name))\r\n            continue\r\n\r\n        ds = DirectShape.CreateElement(doc, cat_id)\r\n        ds.SetShape([geo])\r\n\r\n        room_num = room.get_Parameter(BuiltInParameter.ROOM_NUMBER).AsString() or \"\"\r\n        ds.Name  = \"{} {}\".format(room_name, room_num).strip()\r\n\r\n        comment_parts = []\r\n        for label, param_def in PARAM_MAP:\r\n            val = get_room_value(room, param_def)\r\n            comment_parts.append(\"{}: {}\".format(label, val))\r\n\r\n        p_comments = ds.get_Parameter(BuiltInParameter.ALL_MODEL_INSTANCE_COMMENTS)\r\n        if p_comments:\r\n            p_comments.Set(\" | \".join(comment_parts))\r\n\r\n        ws_param = ds.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM)\r\n        if ws_param and not ws_param.IsReadOnly:\r\n            ws_param.Set(workset_id.IntegerValue)\r\n\r\n        created.append(ds.Name)\r\n\r\n    except Exception as e:\r\n        errors.append(\"{}: {}\".format(room_name, str(e)))\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = [\r\n    \"✓ {} masas creadas en workset '{}'\".format(len(created), WORKSET_NAME),\r\n    errors if errors else \"Sin errores\"\r\n]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
