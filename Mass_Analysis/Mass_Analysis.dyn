  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\nWORKSET_NAME = \"Rooms_3D_Visual\"\r\n\r\n# ── Buscar workset ─────────────────────────────────────────\r\nworkset_id = None\r\nworkset_int = None\r\nfor ws in FilteredWorksetCollector(doc).OfKind(WorksetKind.UserWorkset):\r\n    if ws.Name == WORKSET_NAME:\r\n        workset_id  = ws.Id\r\n        workset_int = ws.Id.IntegerValue\r\n        break\r\n\r\nif workset_id is None:\r\n    OUT = [\"Workset '{}' no encontrado — nada que limpiar.\".format(WORKSET_NAME)]\r\nelse:\r\n    # ── Recoger TODAS las masas y filtrar por workset ──────\r\n    all_masses = FilteredElementCollector(doc)\\\r\n        .OfCategory(BuiltInCategory.OST_Mass)\\\r\n        .WhereElementIsNotElementType()\\\r\n        .ToElements()\r\n\r\n    # Diagnóstico: ver qué workset tiene cada masa\r\n    debug = []\r\n    to_delete = []\r\n\r\n    for m in all_masses:\r\n        ws_param = m.get_Parameter(BuiltInParameter.ELEM_PARTITION_PARAM)\r\n        if ws_param is None:\r\n            debug.append(\"{} → sin param workset\".format(m.Name or \"?\"))\r\n            continue\r\n        mass_ws_int = ws_param.AsInteger()\r\n        debug.append(\"{} → workset ID: {} (buscamos: {})\".format(\r\n            m.Name or \"?\", mass_ws_int, workset_int))\r\n        if mass_ws_int == workset_int:\r\n            to_delete.append(m.Id)\r\n\r\n    # ── Eliminar ───────────────────────────────────────────\r\n    deleted = 0\r\n    if to_delete:\r\n        TransactionManager.Instance.EnsureInTransaction(doc)\r\n        for eid in to_delete:\r\n            try:\r\n                doc.Delete(eid)\r\n                deleted += 1\r\n            except:\r\n                pass\r\n        TransactionManager.Instance.TransactionTaskDone()\r\n\r\n    OUT = [\r\n        \"Workset '{}' ID: {}\".format(WORKSET_NAME, workset_int),\r\n        \"Total masas en modelo: {}\".format(len(list(all_masses))),\r\n        \"Masas a eliminar: {}\".format(len(to_delete)),\r\n        \"Eliminadas: {}\".format(deleted),\r\n        \"Detalle (primeras 10): {}\".format(debug[:10])\r\n    ]",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "0b7a61567d4d4f309b6d1d4c6fd7a08f",
